# Banco de dados (SQLite por padrao; PostgreSQL via URL)
# DATABASE_URL=sqlite:///backend/data/mastermind.db

# Sessao (duracao em horas)
# SESSION_DURATION_HOURS=24

# Cookie
# COOKIE_HTTPONLY=true
# COOKIE_SAMESITE=lax

# CORS
# CORS_ORIGINS=["*"]
# CORS_ALLOW_CREDENTIALS=true
# CORS_ALLOW_METHODS=["*"]
# CORS_ALLOW_HEADERS=["*"]

# FastAPI metadata
# APP_TITLE=Mastermind API
# APP_DESCRIPTION=API REST para o jogo Mastermind
# APP_VERSION=1.0.0
